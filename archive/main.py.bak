import tkinter as tk
from tkinter import filedialog, messagebox
from pathlib import Path

root = tk.Tk()
root.title("BookBuilder")
root.geometry("750x520")

selected = tk.StringVar(root)
selected.set("No book selected")

title = tk.Label(
    root,
    text="BOOKBUILDER",
    font=("Arial",28,"bold")
)
title.pack(pady=20)

status = tk.Label(
    root,
    textvariable=selected,
    wraplength=700
)
status.pack(pady=10)


def convert_book():

    filename = filedialog.askopenfilename(
        title="Select Book",
        filetypes=[
            ("Books","*.epub *.txt *.pdf"),
            ("All Files","*.*")
        ]
    )

    if filename:

        selected.set(Path(filename).name)

        messagebox.showinfo(
            "BookBuilder",
            f"Selected:\n\n{Path(filename).name}"
        )


def coming(name):

    messagebox.showinfo(
        "BookBuilder",
        f"{name}\n\nComing Soon!"
    )


buttons = [

    ("Convert Book",convert_book),

    ("Convert Library",
     lambda:coming("Convert Library")),

    ("Voices",
     lambda:coming("Voice Studio")),

    ("Settings",
     lambda:coming("Settings")),

    ("Exit",
     root.destroy)

]

for text,cmd in buttons:

    tk.Button(

        root,

        text=text,

        width=35,

        height=2,

        command=cmd

    ).pack(pady=5)

root.mainloop()
